# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real keys

# ─── Supabase ─────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your-anon-key-here

# ─── Anthropic ────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
# Server-side only — NEVER prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App URL (used by /api/validate to fetch reference sticker images) ────
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (set this in Vercel environment variables):
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Farcaster MiniApp ────────────────────────────────────────────────────
# Your production domain (no protocol, no trailing slash) — used by Quick Auth JWT verification
# e.g. NEXT_PUBLIC_APP_DOMAIN=streethunt.app
NEXT_PUBLIC_APP_DOMAIN=streethunt.vercel.app

# ─── Admin ────────────────────────────────────────────────────────────────
# Simple shared secret to protect /admin and /api/admin/* routes
ADMIN_SECRET=change-me-to-something-secret

# Supabase service role key (server-only — NEVER prefix with NEXT_PUBLIC_)
# Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here
